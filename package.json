{
  "name": "studio32-agent",
  "version": "0.2.0",
  "description": "Studio32 Agent Core: agente conversacional multi-tenant para negocios locales (WhatsApp; futuro voz). Atiende, capta leads y gestiona reservas en Google Calendar.",
  "main": "src/server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "chat": "node test-cli.js",
    "test:agent": "node test-cli.js --smoke",
    "check": "node src/check.js",
    "test:llm": "node test-llm.js",
    "test:qa": "node test-qa.js",
    "test:sec": "node test-security.js",
    "check:supabase": "node scripts/check-supabase-schema.js",
    "test:supabase": "node --test test/supabase-adapter.test.js",
    "supabase:import": "node scripts/import-tenants-to-supabase.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "nodemailer": "^6.9.14",
    "openai": "^4.67.0",
    "twilio": "^5.3.0"
  }
}
